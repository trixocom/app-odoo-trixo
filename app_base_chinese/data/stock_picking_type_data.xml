<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <function model="stock.picking.type" name="write" context="{'lang': 'zh_CN'}">
            <value model="stock.picking.type" eval="obj().search([('name', '=', 'Dropship')]).ids"/>
            <value model="stock.picking.type" eval="{
                'name': '供应商直发单',
            }"/>
        </function>
        <function model="stock.picking.type" name="write" context="{'lang': 'zh_CN'}">
            <value model="stock.picking.type" eval="obj().search([('name', '=', 'Manufacturing')]).ids"/>
            <value model="stock.picking.type" eval="{
                'name': '生产派工单',
            }"/>
        </function>
    </data>
</odoo>
